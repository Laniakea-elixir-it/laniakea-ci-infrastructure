pipeline {
	agent { label "build-usegalaxy-it.wn1" }
	options { disableConcurrentBuilds() }

	environment {
		ANSIBLE_HOST_KEY_CHECKING = 'False'
	}

	parameters {
		string(name: 'TARGET_HOSTS', defaultValue: 'galaxyservers', description: 'Host Ansible target')
		string(name: 'PLAYBOOK_DIR', defaultValue: 'galaxy', description: 'Playbook directory and name')
		string(name: 'PLAYBOOK_FILE', defaultValue: 'galaxy.yml', description: 'Playbook name')
		string(name: 'IMAGE', defaultValue: 'RockyLinux_9.5_20241118', description: 'Cloud image name')
	}

	stages {

                stage('Create build environment') {
                        steps {
                                withCredentials([string(credentialsId: 'iam-recas-laniakea-bot-password', variable: 'IAM_CLIENT_PASSWORD')]) {
                                        sh '''
                                        python3 -m venv build/
                                        . build/bin/activate
                                        pip install -r ./roles-tests/requirements.txt
                                        '''
                                }
                        }
                }
		stage('Deploy VM') {
		        environment {
                		PLAYBOOK_DIR  = "${params.PLAYBOOK_DIR}"
		                PLAYBOOK_FILE = "${params.PLAYBOOK_FILE}"
                		TARGET_HOSTS  = "${params.TARGET_HOSTS}"
            		}
			steps {
				withCredentials([string(credentialsId: 'iam-recas-laniakea-bot-password', variable: 'IAM_CLIENT_PASSWORD')]) {
					sh '''
                                	# Openstack Access
                                	. build/bin/activate
                                	eval `oidc-agent-service use`
                                	. /home/ubuntu/usegalaxy-it.sh
                                	expect ./expect.sh $IAM_CLIENT_PASSWORD
                                	export IAM_ACCESS_TOKEN=$(oidc-token iam-recas-laniakea-bot)
                                	export OS_TOKEN=$(openstack --os-auth-type v3oidcaccesstoken --os-access-token ${IAM_ACCESS_TOKEN} token issue  -f json | jq -r '.id')
                                	echo $OS_TOKEN

					cd roles-tests

                                	# Configure Terraform:
                                	# clone the terraform recipe,
                                	# configure the tf provider,
                                	# create the infrastructure using the image var selected in the action trigger,
                                	# save the public ip of the VM to configure the host file later.
                                	git clone https://github.com/Laniakea-elixir-it/TerraFormExpress.git
                                	cd TerraFormExpress
                                	terraform init
                                	terraform apply -auto-approve -var="image_name=$IMAGE"
                                	export VM_IP=$(terraform output -raw public_ip)
                                	echo $VM_IP
                                	cd ..

					# Install Galaxy
					git submodule update --init --recursive
		                        ansible-galaxy role install -r ./ansible-playbooks/${params.PLAYBOOK_DIR}/requirements.yml -p roles
					cat hosts
					ansible-playbook -i ../TerraFormExpress/hosts ansible-playbooks/${params.PLAYBOOK_DIR}/${params.PLAYBOOK_FILE}
					'''
				}
			}
		}
	}

        post {
                success {
                        emailext (
                        subject: '$DEFAULT_SUBJECT',
                        body: '$DEFAULT_CONTENT',
                        to: '$DEFAULT_RECIPIENTS',
                        attachLog: true
                        )
                        cleanWs()
                }
                failure {
                        emailext (
                        subject: '$DEFAULT_SUBJECT',
                        body: '$DEFAULT_CONTENT',
                        to: '$DEFAULT_RECIPIENTS',
                        attachLog: true
                        )
                        cleanWs()
                }
        }
}
