pipeline {
    agent { label "build-usegalaxy-it.wn1" }
    options { disableConcurrentBuilds() }
    
    environment {
        ANSIBLE_HOST_KEY_CHECKING = 'False'
    }

    stages {
        stage('Deploy VPN Jump Hosts') {
            steps {
                withCredentials([
                    string(credentialsId: 'laniakea_vault_password', variable: 'LANIAKEA_VAULT_PASSWORD'),
                    sshUserPrivateKey(credentialsId: 'laniakea_robot_ssh_key_pair', keyFileVariable: 'SSH_KEY')
                ]) {
                    dir('vpn_jump_hosts') {
                        sh '''#!/bin/bash
                        python3 -m venv venv
                        . venv/bin/activate
                        pip install -r requirements.txt
                        ansible-galaxy role install -r requirements.yml -p roles
                        IPS=$(ansible-vault view inventory/hosts --vault-password-file <(echo "$LANIAKEA_VAULT_PASSWORD") | grep ansible_host | awk -F'ansible_host=' '{print $2}' | awk '{print $1}')
                        for IP in $IPS; do
                            ssh-keygen -f "$HOME/.ssh/known_hosts" -R "$IP"
                            ssh-keyscan -H "$IP" >> "$HOME/.ssh/known_hosts"
                        done
                        ansible-playbook -i inventory/hosts configure_jump_host.yml --vault-password-file <(echo "$LANIAKEA_VAULT_PASSWORD") --private-key "$SSH_KEY" -u root
                        ansible-playbook -i inventory/hosts wireguard.yml --vault-password-file <(echo "$LANIAKEA_VAULT_PASSWORD") --private-key "$SSH_KEY" -u root
                        '''
                    }
                }
            }
        }
    }

        post {
                success {
                        emailext (
                        subject: '$DEFAULT_SUBJECT',
                        body: '$DEFAULT_CONTENT',
                        to: '$DEFAULT_RECIPIENTS',
                        attachLog: true
                        )
                        cleanWs()
                }
                failure {
                        emailext (
                        subject: '$DEFAULT_SUBJECT',
                        body: '$DEFAULT_CONTENT',
                        to: '$DEFAULT_RECIPIENTS',
                        attachLog: true
                        )
                        cleanWs()
                }
        }
}
